# Copy to .env and fill in values. Never commit .env itself.

# Dev: SQLite file. Production: Neon Postgres connection string
# (also change datasource provider to "postgresql" in prisma/schema.prisma).
DATABASE_URL="postgresql://neondb_owner:********@ep-withered-waterfall-ayj8kltf-pooler.c-5.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Admin login seeded by `npm run db:seed` (override before seeding).
# ADMIN_EMAIL="artaeflora@gmail.com"
# ADMIN_PASSWORD="change-me"

# Step 4+ (Stripe checkout) — test keys from dashboard.stripe.com
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Step 5+ (NextAuth admin sessions) — generate with: openssl rand -base64 32
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="http://localhost:3000"

# Step 5+ (Cloudinary image uploads) — omit locally to store files in public/uploads
# CLOUDINARY_URL=""

# Log verbosity: debug | info (default) | warn | error
# LOG_LEVEL="info"

# Public site URL — used in sitemap, robots, and OpenGraph metadata.
# Set to https://artaeflora.com in production.
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
